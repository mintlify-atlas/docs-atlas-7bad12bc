  "keyFeatures": [
    "Ensures scheduled tasks run at most once simultaneously across distributed nodes",
    "Supports 20+ lock provider backends (JDBC, MongoDB, Redis, Hazelcast, ZooKeeper, etc.)",
    "First-class Spring integration via @EnableSchedulerLock and @SchedulerLock annotations",
    "Micronaut and CDI (Quarkus) framework support",
    "Time-based lock expiry (lockAtMostFor) for crash safety",
    "Minimum lock duration (lockAtLeastFor) to prevent rapid re-execution",
    "Lock extension support via LockExtender and KeepAliveLockProvider",
    "Multi-tenancy support with custom LockProvider wrappers",
    "Micrometer metrics integration for observability",
    "Multiple LockProvider support with @LockProviderToUse disambiguation"
  ],
  "publicApiSurface": [
    "@EnableSchedulerLock(defaultLockAtMostFor, interceptMode)",
    "@SchedulerLock(name, lockAtMostFor, lockAtLeastFor)",
    "LockProvider interface",
    "SimpleLock interface",
    "LockConfiguration",
    "LockingTaskExecutor / DefaultLockingTaskExecutor",
    "LockAssert.assertLocked()",
    "LockExtender.extendActiveLock()",
    "KeepAliveLockProvider",
    "JdbcTemplateLockProvider",
    "MongoLockProvider",
    "RedisLockProvider / ReactiveRedisLockProvider / JedisLockProvider / LettuceLockProvider",
    "DynamoDBLockProvider",
    "ZookeeperCuratorLockProvider",
    "HazelcastLockProvider",
    "CassandraLockProvider",
    "R2dbcLockProvider",
    "InMemoryLockProvider",
    "MicrometerLockingTaskExecutorListener",
    "@LockProviderToUse"
  ]
